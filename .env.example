# devmark Dashboard — Variables de Entorno
# Copia este archivo como .env.local y rellena cada valor
# NUNCA subas credenciales a GitHub

# ─── Base de Datos (PostgreSQL directo) ──────────────────────────────────────
DATABASE_URL=postgresql://devmark_user:TU_PASSWORD@localhost:5432/devmark

# ─── API Core ────────────────────────────────────────────────────────────────
CORE_API_URL=http://127.0.0.1:8000
DASHBOARD_API_SECRET=TU_SECRET_COMPARTIDO_CON_CORE

# ─── NextAuth ────────────────────────────────────────────────────────────────
NEXTAUTH_SECRET=TU_NEXTAUTH_SECRET
NEXTAUTH_URL=https://app.devmark.mx

# ─── Admin Login ─────────────────────────────────────────────────────────────
ADMIN_EMAIL=tu@email.com
ADMIN_PASSWORD_HASH=TU_HASH_BCRYPT_AQUI

# ─── Jira (solo dominio para enlaces) ───────────────────────────────────────
NEXT_PUBLIC_JIRA_DOMAIN=tuempresa.atlassian.net
